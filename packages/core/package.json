{
    "name": "@my-table/core",
    "version": "0.1.0",
    "description": "Framework-agnostic headless table engine",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    },
    "files": ["dist"],
    "sideEffects": false,
    "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "test": "vitest run",
      "typecheck": "tsc --noEmit",
      "clean": "rm -rf dist"
    },
    "devDependencies": {
      "tsup": "^8.1.0",
      "typescript": "^5.5.3",
      "vitest": "^2.0.2"
    },
    "publishConfig": {
      "access": "public"
    },
    "keywords": ["table", "datagrid", "headless", "typescript"],
    "license": "MIT"
  }