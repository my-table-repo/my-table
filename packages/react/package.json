{
    "name": "@my-table/react",
    "version": "0.1.0",
    "description": "React bindings for @my-table/core",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "files": ["dist"],
    "sideEffects": false,
    "scripts": {
      "build": "tsup",
      "dev": "tsup --watch",
      "test": "vitest run",
      "typecheck": "tsc --noEmit",
      "clean": "rm -rf dist"
    },
    "peerDependencies": {
      "react": ">=18.0.0",
      "react-dom": ">=18.0.0"
    },
    "dependencies": {
      "@my-table/core": "workspace:*"
    },
    "devDependencies": {
      "@types/react": "^18.3.3",
      "@types/react-dom": "^18.3.0",
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "tsup": "^8.1.0",
      "typescript": "^5.5.3",
      "vitest": "^2.0.2",
      "@testing-library/react": "^16.0.0"
    },
    "publishConfig": {
      "access": "public"
    }
  }